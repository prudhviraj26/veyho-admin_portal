generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Group {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(300)
  status    String   @default("active") // active / suspended / dissolved
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  schools   School[]
  staff     Staff[]

  @@map("groups")
}

model School {
  id             String  @id @default(uuid()) @db.Uuid
  groupId        String  @map("group_id") @db.Uuid
  name           String  @db.VarChar(300)
  shortName      String? @map("short_name") @db.VarChar(10)
  logoBlobPath   String? @map("logo_blob_path") @db.VarChar(500)
  primaryColor   String  @default("#1F4E78") @map("primary_color") @db.VarChar(7)
  secondaryColor String? @map("secondary_color") @db.VarChar(7)
  status                 SchoolStatus            @default(ACTIVE)
  pausedAt               DateTime?               @map("paused_at")
  pausedReason           String?                 @map("paused_reason") @db.Text
  archivedAt             DateTime?               @map("archived_at")
  archivedReason         String?                 @map("archived_reason") @db.Text
  deletedAt              DateTime?               @map("deleted_at")
  deletedReason          String?                 @map("deleted_reason") @db.Text
  deletedBy              String?                 @map("deleted_by") @db.Uuid
  restoreDeadline        DateTime?               @map("restore_deadline")
  purgedAt               DateTime?               @map("purged_at")
  purgedBy               String?                 @map("purged_by") @db.Uuid
  purgeStatus            String?                 @map("purge_status") @db.VarChar(20)
  statusHistory          SchoolStatusHistory[]

  // School Information
  schoolType             String? @map("school_type") @db.VarChar(30)
  establishmentYear      Int?    @map("establishment_year")
  boardAffiliationNumber String? @map("board_affiliation_number") @db.VarChar(50)
  boardName              String? @map("board_name") @db.VarChar(100)
  udiseCode              String? @map("udise_code") @db.VarChar(11)
  principalName          String? @map("principal_name") @db.VarChar(200)

  // Contact Details
  phonePrimary   String? @map("phone_primary") @db.VarChar(20)
  phoneSecondary String? @map("phone_secondary") @db.VarChar(20)
  emailPrimary   String? @map("email_primary") @db.VarChar(255)
  websiteUrl     String? @map("website_url") @db.VarChar(500)
  addressLine1   String? @map("address_line_1")
  addressLine2   String? @map("address_line_2")
  city           String? @db.VarChar(100)
  state          String? @db.VarChar(100)
  pincode        String? @db.VarChar(6)

  // GST
  gstin String? @db.VarChar(15)

  // School Timings (HH:MM format)
  schoolStartTime String? @map("school_start_time") @db.VarChar(5)
  schoolEndTime   String? @map("school_end_time") @db.VarChar(5)

  // Working Days — JSON array of lowercase day names
  workingDays Json @default("[\"monday\",\"tuesday\",\"wednesday\",\"thursday\",\"friday\",\"saturday\"]") @map("working_days") @db.JsonB

  // DPDP Data Retention Policy
  retentionPolicyYears   Int       @default(7) @map("retention_policy_years")
  retentionPolicyEnabled Boolean   @default(true) @map("retention_policy_enabled")
  retentionLastRunAt     DateTime? @map("retention_last_run_at")

  // Feature Toggles
  staffAttendanceEnabled Boolean @default(false) @map("staff_attendance_enabled")

  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  updatedByStaffId       String?                 @map("updated_by_staff_id") @db.Uuid
  group                  Group                   @relation(fields: [groupId], references: [id])
  staffRoles             StaffSchoolRole[]
  academicYears          AcademicYear[]
  classes                Class[]
  sections               Section[]
  students               Student[]
  parentContacts         ParentContact[]
  familyGroups           FamilyGroup[]
  enrollments            Enrollment[]
  admissions             Admission[]
  holidays               SchoolHoliday[]
  attendanceSessions     AttendanceSession[]
  staffAttendanceRecords StaffAttendanceRecord[]
  feeCategories          FeeCategory[]
  feeStructures          FeeStructure[]
  studentFeeAccounts     StudentFeeAccount[]
  feePayments            FeePayment[]
  feeReceipts            FeeReceipt[]
  broadcasts             Broadcast[]
  chatThreads            ChatThread[]
  notificationRules      NotificationRule[]
  promotionRuns          PromotionRun[]
  supportAccessGrants    SupportAccessGrant[]

  @@map("schools")
}

model SchoolHoliday {
  id               String   @id @default(uuid()) @db.Uuid
  schoolId         String   @map("school_id") @db.Uuid
  academicYearId   String   @map("academic_year_id") @db.Uuid
  date             DateTime @db.Date
  name             String   @db.VarChar(200) // "Diwali", "Republic Day", "Summer Vacation Day 1"
  description      String?  @db.Text
  isFullDay        Boolean  @default(true) @map("is_full_day") // future-proof for half-day holidays
  appliesTo        String   @default("all") @map("applies_to") // "all" | "specific_classes" — Phase 1 always "all"
  createdByStaffId String   @map("created_by_staff_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  updatedByStaffId String?  @map("updated_by_staff_id") @db.Uuid
  school           School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, date])
  @@index([academicYearId, date])
  @@map("school_holidays")
}

model AttendanceSession {
  id               String                    @id @default(uuid()) @db.Uuid
  schoolId         String                    @map("school_id") @db.Uuid
  academicYearId   String                    @map("academic_year_id") @db.Uuid
  sectionId        String                    @map("section_id") @db.Uuid
  date             DateTime                  @db.Date
  markedByStaffId  String                    @map("marked_by_staff_id") @db.Uuid
  markedAt         DateTime                  @map("marked_at")
  totalStudents    Int                       @map("total_students")
  presentCount     Int                       @map("present_count")
  absentCount      Int                       @map("absent_count")
  lateCount        Int                       @map("late_count")
  halfDayCount     Int                       @map("half_day_count")
  status           String                    @default("submitted") // submitted | locked | voided
  notes            String?                   @db.Text
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  updatedByStaffId String?                   @map("updated_by_staff_id") @db.Uuid
  school           School                    @relation(fields: [schoolId], references: [id])
  section          Section                   @relation(fields: [sectionId], references: [id])
  studentRecords   StudentAttendanceRecord[]

  @@unique([sectionId, date])
  @@index([schoolId, date])
  @@index([academicYearId, date])
  @@map("attendance_sessions")
}

model StudentAttendanceRecord {
  id                   String            @id @default(uuid()) @db.Uuid
  attendanceSessionId  String            @map("attendance_session_id") @db.Uuid
  schoolId             String            @map("school_id") @db.Uuid
  studentId            String            @map("student_id") @db.Uuid
  enrollmentId         String            @map("enrollment_id") @db.Uuid // snapshot — student's enrollment at the time
  date                 DateTime          @db.Date // denormalized for fast filtering
  status               String // present | absent | late | half_day | school_holiday
  isCurrent            Boolean           @default(true) @map("is_current")
  supersededByRecordId String?           @map("superseded_by_record_id") @db.Uuid
  markedByStaffId      String            @map("marked_by_staff_id") @db.Uuid
  markedAt             DateTime          @map("marked_at")
  reason               String?           @db.Text // for absences: "Sick", "Family function" — optional
  notes                String?           @db.Text // teacher's free-text note
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedByStaffId     String?           @map("updated_by_staff_id") @db.Uuid
  session              AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)

  @@index([studentId, date, isCurrent])
  @@index([schoolId, date, isCurrent])
  @@index([attendanceSessionId, isCurrent])
  @@map("student_attendance_records")
}

model AttendanceCorrectionRequest {
  id                        String    @id @default(uuid()) @db.Uuid
  schoolId                  String    @map("school_id") @db.Uuid
  studentAttendanceRecordId String    @map("student_attendance_record_id") @db.Uuid
  studentId                 String    @map("student_id") @db.Uuid
  sectionId                 String    @map("section_id") @db.Uuid
  date                      DateTime  @db.Date
  fromStatus                String    @map("from_status")
  toStatus                  String    @map("to_status")
  reason                    String    @db.Text // teacher's justification
  requestedByStaffId        String    @map("requested_by_staff_id") @db.Uuid
  status                    String    @default("pending") // pending | approved | rejected
  reviewedByStaffId         String?   @map("reviewed_by_staff_id") @db.Uuid
  reviewedAt                DateTime? @map("reviewed_at")
  reviewNotes               String?   @map("review_notes") @db.Text
  appliedRecordId           String?   @map("applied_record_id") @db.Uuid
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  updatedByStaffId String? @map("updated_by_staff_id") @db.Uuid
  requestedByStaff Staff   @relation("RequestedCorrections", fields: [requestedByStaffId], references: [id])
  reviewedByStaff  Staff?  @relation("ReviewedCorrections", fields: [reviewedByStaffId], references: [id])

  @@index([schoolId, status])
  @@index([sectionId, status])
  @@map("attendance_correction_requests")
}

model Admission {
  id                    String                   @id @default(uuid()) @db.Uuid
  schoolId              String                   @map("school_id") @db.Uuid
  inquiryNumber         String                   @map("inquiry_number") @db.VarChar(30) // ADM/2627/0001 format
  applicantFirstName    String                   @map("applicant_first_name") @db.VarChar(100)
  applicantMiddleName   String?                  @map("applicant_middle_name") @db.VarChar(100)
  applicantLastName     String                   @map("applicant_last_name") @db.VarChar(100)
  applicantDateOfBirth  DateTime                 @map("applicant_date_of_birth") @db.Date
  applicantGender       String                   @map("applicant_gender") // male | female | other
  academicYearId        String                   @map("academic_year_id") @db.Uuid
  requestedClassId      String                   @map("requested_class_id") @db.Uuid
  preferredSectionId    String?                  @map("preferred_section_id") @db.Uuid
  parentName            String                   @map("parent_name") @db.VarChar(200)
  parentRelationship    String                   @map("parent_relationship") @db.VarChar(20) // father | mother | guardian
  parentMobile          String                   @map("parent_mobile") @db.VarChar(15)
  parentEmail           String?                  @map("parent_email") @db.VarChar(255)
  inquirySource         String?                  @map("inquiry_source") @db.VarChar(50)
  referredBy            String?                  @map("referred_by") @db.VarChar(200)
  status                String                   @default("inquiry")
  interviewScheduledAt  DateTime?                @map("interview_scheduled_at")
  interviewLocation     String?                  @map("interview_location") @db.VarChar(200)
  interviewerStaffId    String?                  @map("interviewer_staff_id") @db.Uuid
  interviewNotes        String?                  @map("interview_notes") @db.Text
  interviewScore        Int?                     @map("interview_score")
  decisionMadeAt        DateTime?                @map("decision_made_at")
  decisionMadeByStaffId String?                  @map("decision_made_by_staff_id") @db.Uuid
  rejectionReason       String?                  @map("rejection_reason") @db.Text
  convertedToStudentId  String?                  @unique @map("converted_to_student_id") @db.Uuid
  convertedAt           DateTime?                @map("converted_at")
  previousSchoolName    String?                  @map("previous_school_name") @db.VarChar(300)
  previousSchoolClass   String?                  @map("previous_school_class") @db.VarChar(50)
  previousSchoolBoard   String?                  @map("previous_school_board") @db.VarChar(100)
  tcNumber              String?                  @map("tc_number") @db.VarChar(100)
  applicationType       String                   @default("fresh") @map("application_type")
  // "fresh" | "transfer" | "re_admission"
  notes                 String?                  @db.Text
  createdByStaffId      String                   @map("created_by_staff_id") @db.Uuid
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")
  updatedByStaffId      String?                  @map("updated_by_staff_id") @db.Uuid
  school                School                   @relation(fields: [schoolId], references: [id])
  requestedClass        Class                    @relation("RequestedClassAdmissions", fields: [requestedClassId], references: [id])
  documents             AdmissionDocument[]
  statusHistory         AdmissionStatusHistory[]

  @@unique([schoolId, inquiryNumber])
  @@index([schoolId, status])
  @@index([schoolId, academicYearId, status])
  @@index([parentMobile])
  @@map("admissions")
}

model AdmissionDocument {
  id                String    @id @default(uuid()) @db.Uuid
  admissionId       String    @map("admission_id") @db.Uuid
  documentType      String    @map("document_type") @db.VarChar(50)
  isReceived        Boolean   @default(false) @map("is_received")
  blobPath          String?   @map("blob_path") @db.VarChar(500)
  fileName          String?   @map("file_name") @db.VarChar(300)
  fileSizeBytes     Int?      @map("file_size_bytes")
  mimeType          String?   @map("mime_type") @db.VarChar(100)
  receivedAt        DateTime? @map("received_at")
  receivedByStaffId String?   @map("received_by_staff_id") @db.Uuid
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  updatedByStaffId  String?   @map("updated_by_staff_id") @db.Uuid
  admission         Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@unique([admissionId, documentType])
  @@map("admission_documents")
}

model AdmissionStatusHistory {
  id               String    @id @default(uuid()) @db.Uuid
  admissionId      String    @map("admission_id") @db.Uuid
  fromStatus       String?   @map("from_status") @db.VarChar(30)
  toStatus         String    @map("to_status") @db.VarChar(30)
  reason           String?   @db.Text
  changedByStaffId String    @map("changed_by_staff_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  admission        Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([admissionId])
  @@map("admission_status_history")
}

model FamilyGroup {
  id               String          @id @default(uuid()) @db.Uuid
  schoolId         String          @map("school_id") @db.Uuid
  familyName       String?         @map("family_name") @db.VarChar(200)
  notes            String?         @db.Text
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  updatedByStaffId String?         @map("updated_by_staff_id") @db.Uuid
  school           School          @relation(fields: [schoolId], references: [id])
  students         Student[]
  parentContacts   ParentContact[]

  @@index([schoolId])
  @@map("family_groups")
}

model ParentContact {
  id            String  @id @default(uuid()) @db.Uuid
  schoolId      String  @map("school_id") @db.Uuid
  familyGroupId String? @map("family_group_id") @db.Uuid

  // Father's details
  fatherFirstName    String? @map("father_first_name") @db.VarChar(100)
  fatherLastName     String? @map("father_last_name") @db.VarChar(100)
  fatherMobile       String? @map("father_mobile") @db.VarChar(15)
  fatherEmail        String? @map("father_email") @db.VarChar(255)
  fatherOccupation   String? @map("father_occupation") @db.VarChar(200)
  fatherWorkplace    String? @map("father_workplace") @db.VarChar(300)
  fatherAnnualIncome Int?    @map("father_annual_income")

  // Mother's details
  motherFirstName    String? @map("mother_first_name") @db.VarChar(100)
  motherLastName     String? @map("mother_last_name") @db.VarChar(100)
  motherMobile       String? @map("mother_mobile") @db.VarChar(15)
  motherEmail        String? @map("mother_email") @db.VarChar(255)
  motherOccupation   String? @map("mother_occupation") @db.VarChar(200)
  motherWorkplace    String? @map("mother_workplace") @db.VarChar(300)
  motherAnnualIncome Int?    @map("mother_annual_income")

  // Optional guardian
  guardianFirstName    String? @map("guardian_first_name") @db.VarChar(100)
  guardianLastName     String? @map("guardian_last_name") @db.VarChar(100)
  guardianRelationship String? @map("guardian_relationship") @db.VarChar(50)
  guardianMobile       String? @map("guardian_mobile") @db.VarChar(15)
  guardianEmail        String? @map("guardian_email") @db.VarChar(255)
  guardianOccupation   String? @map("guardian_occupation") @db.VarChar(200)

  // Primary contact selector
  primaryContact String @map("primary_contact")

  // Pickup permissions
  fatherCanPickUp   Boolean @default(true) @map("father_can_pick_up")
  motherCanPickUp   Boolean @default(true) @map("mother_can_pick_up")
  guardianCanPickUp Boolean @default(false) @map("guardian_can_pick_up")

  // Shared address
  addressLine String? @map("address_line") @db.VarChar(500)
  city        String? @db.VarChar(100)
  state       String? @db.VarChar(100)
  pincode     String? @db.VarChar(10)

  // Communication preferences
  preferredLanguage String @default("en") @map("preferred_language") @db.VarChar(10)

  fatherMobileVerifiedAt   DateTime? @map("father_mobile_verified_at")
  motherMobileVerifiedAt   DateTime? @map("mother_mobile_verified_at")
  guardianMobileVerifiedAt DateTime? @map("guardian_mobile_verified_at")

  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  updatedByStaffId String?  @map("updated_by_staff_id") @db.Uuid

  school              School                 @relation(fields: [schoolId], references: [id])
  familyGroup         FamilyGroup?           @relation(fields: [familyGroupId], references: [id], onDelete: SetNull)
  studentLinks        StudentParentContact[]
  chatThreads         ChatThread[]
  broadcastRecipients BroadcastRecipient[]

  @@index([schoolId, fatherMobile])
  @@index([schoolId, motherMobile])
  @@index([schoolId, guardianMobile])
  @@map("parent_contacts")
}

model Student {
  id                  String                 @id @default(uuid()) @db.Uuid
  schoolId            String                 @map("school_id") @db.Uuid
  familyGroupId       String?                @map("family_group_id") @db.Uuid
  // Identifiers
  admissionNumber     String?                @map("admission_number") @db.VarChar(30)
  apaarId             String?                @map("apaar_id") @db.VarChar(20)
  penNumber           String?                @map("pen_number") @db.VarChar(20)
  aadhaarNumber       String?                @map("aadhaar_number") @db.VarChar(12)
  // Personal
  firstName           String                 @map("first_name") @db.VarChar(100)
  middleName          String?                @map("middle_name") @db.VarChar(100)
  lastName            String                 @map("last_name") @db.VarChar(100)
  dateOfBirth         DateTime               @map("date_of_birth") @db.Date
  gender              String
  bloodGroup          String?                @map("blood_group") @db.VarChar(5)
  nationality         String                 @default("Indian")
  religion            String?                @db.VarChar(50)
  category            String?                @db.VarChar(200)
  motherTongue        String?                @map("mother_tongue") @db.VarChar(50)
  caste               String?                @db.VarChar(100)
  dateOfBirthInWords  String?                @map("date_of_birth_in_words") @db.VarChar(300)
  // Contact
  addressLine         String?                @map("address_line") @db.VarChar(500)
  city                String?                @db.VarChar(100)
  state               String?                @db.VarChar(100)
  pincode             String?                @db.VarChar(10)
  photoBlobPath       String?                @map("photo_blob_path") @db.VarChar(500)
  // Status
  status              String                 @default("active")
  admittedOn          DateTime               @map("admitted_on") @db.Date
  withdrawnOn         DateTime?              @map("withdrawn_on") @db.Date
  withdrawalReason    String?                @map("withdrawal_reason") @db.Text
  previousSchoolName  String?                @map("previous_school_name") @db.VarChar(300)
  previousSchoolClass String?                @map("previous_school_class") @db.VarChar(50)
  previousSchoolBoard String?                @map("previous_school_board") @db.VarChar(100)
  previousBoardType   String?                @map("previous_board_type") @db.VarChar(50)
  previousBoardState  String?                @map("previous_board_state") @db.VarChar(100)
  previousBoardName   String?                @map("previous_board_name") @db.VarChar(300)
  tcNumber            String?                @map("tc_number") @db.VarChar(100)
  applicationType     String                 @default("fresh") @map("application_type")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")
  updatedByStaffId    String?                @map("updated_by_staff_id") @db.Uuid
  school              School                 @relation(fields: [schoolId], references: [id])
  familyGroup         FamilyGroup?           @relation(fields: [familyGroupId], references: [id])
  enrollments         Enrollment[]
  parentContactLinks  StudentParentContact[]
  medicalInfo         StudentMedicalInfo?
  feeAccounts         StudentFeeAccount[]
  chatThreads         ChatThread[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, status])
  @@index([schoolId, lastName, firstName])
  @@index([updatedByStaffId])
  @@map("students")
}

model StudentParentContact {
  id              String        @id @default(uuid()) @db.Uuid
  studentId       String        @map("student_id") @db.Uuid
  parentContactId String        @map("parent_contact_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parentContact   ParentContact @relation(fields: [parentContactId], references: [id], onDelete: Restrict)

  @@unique([studentId, parentContactId])
  @@index([parentContactId])
  @@map("student_parent_contacts")
}

model Enrollment {
  id               String              @id @default(uuid()) @db.Uuid
  schoolId         String              @map("school_id") @db.Uuid
  studentId        String              @map("student_id") @db.Uuid
  academicYearId   String              @map("academic_year_id") @db.Uuid
  classId          String              @map("class_id") @db.Uuid
  sectionId        String              @map("section_id") @db.Uuid
  rollNumber       Int?                @map("roll_number")
  enrollmentDate   DateTime            @map("enrollment_date") @db.Date
  status           String              @default("enrolled")
  endedOn          DateTime?           @map("ended_on") @db.Date
  endReason        String?             @map("end_reason") @db.Text
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  updatedByStaffId String?             @map("updated_by_staff_id") @db.Uuid
  school           School              @relation(fields: [schoolId], references: [id])
  student          Student             @relation(fields: [studentId], references: [id])
  academicYear     AcademicYear        @relation(fields: [academicYearId], references: [id])
  class            Class               @relation(fields: [classId], references: [id])
  section          Section             @relation(fields: [sectionId], references: [id])
  feeAccounts      StudentFeeAccount[]
  completionReason    String?  @map("completion_reason")
  completedAt         DateTime? @map("completed_at")
  completedByStaffId  String?  @map("completed_by_staff_id") @db.Uuid
  nextEnrollmentId    String?  @unique @map("next_enrollment_id") @db.Uuid
  previousEnrollmentId String? @map("previous_enrollment_id") @db.Uuid

  nextEnrollment       Enrollment?  @relation("EnrollmentHistory", fields: [nextEnrollmentId], references: [id])
  previousEnrollment   Enrollment?  @relation("EnrollmentHistory")

  @@unique([studentId, academicYearId, status], map: "uq_enrollment_active_per_year")
  @@index([schoolId])
  @@index([sectionId])
  @@index([academicYearId, classId, sectionId])
  @@index([studentId])
  @@index([updatedByStaffId])
  @@map("enrollments")
}

model StudentMedicalInfo {
  id                       String   @id @default(uuid()) @db.Uuid
  studentId                String   @unique @map("student_id") @db.Uuid
  bloodGroup               String?  @map("blood_group") @db.VarChar(5)
  allergies                String?  @db.Text
  chronicConditions        String?  @map("chronic_conditions") @db.Text
