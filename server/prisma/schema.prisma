  cancelledByStaffId String?              @map("cancelled_by_staff_id") @db.Uuid
  cancelReason       String?              @map("cancel_reason") @db.Text
  failureReason      String?              @map("failure_reason") @db.Text
  retryCount         Int                  @default(0) @map("retry_count")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  updatedByStaffId   String?              @map("updated_by_staff_id") @db.Uuid
  school             School               @relation(fields: [schoolId], references: [id])
  recipients         BroadcastRecipient[]
  rule               NotificationRule?    @relation(fields: [triggeredByRuleId], references: [id])

  @@index([schoolId, status])
  @@index([scheduledFor, status])
  @@index([schoolId, sentAt])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id                  String         @id @default(uuid()) @db.Uuid
  broadcastId         String         @map("broadcast_id") @db.Uuid
  parentContactId     String?        @map("parent_contact_id") @db.Uuid
  staffId             String?        @map("staff_id") @db.Uuid
  pushDeliveryStatus  String?        @map("push_delivery_status")
  inAppDeliveryStatus String         @default("delivered") @map("in_app_delivery_status")
  readAt              DateTime?      @map("read_at")
  linkedStudentId     String?        @map("linked_student_id") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at")
  broadcast           Broadcast      @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  parentContact       ParentContact? @relation(fields: [parentContactId], references: [id])
  staff               Staff?         @relation(fields: [staffId], references: [id])

  @@index([broadcastId])
  @@index([parentContactId, readAt])
  @@index([staffId, readAt])
  @@map("broadcast_recipients")
}

model ChatThread {
  id                  String        @id @default(uuid()) @db.Uuid
  schoolId            String        @map("school_id") @db.Uuid
  academicYearId      String        @map("academic_year_id") @db.Uuid
  studentId           String        @map("student_id") @db.Uuid
  parentContactId     String        @map("parent_contact_id") @db.Uuid
  classTeacherStaffId String        @map("class_teacher_staff_id") @db.Uuid
  sectionId           String        @map("section_id") @db.Uuid
  status              String        @default("active")
  lastMessageAt       DateTime?     @map("last_message_at")
  lastMessagePreview  String?       @map("last_message_preview") @db.VarChar(200)
  parentUnreadCount   Int           @default(0) @map("parent_unread_count")
  teacherUnreadCount  Int           @default(0) @map("teacher_unread_count")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  updatedByStaffId    String?       @map("updated_by_staff_id") @db.Uuid
  school              School        @relation(fields: [schoolId], references: [id])
  student             Student       @relation(fields: [studentId], references: [id])
  parentContact       ParentContact @relation(fields: [parentContactId], references: [id])
  teacher             Staff         @relation(fields: [classTeacherStaffId], references: [id])

  messages ChatMessage[]

  @@unique([studentId, parentContactId, classTeacherStaffId, academicYearId])
  @@index([schoolId, lastMessageAt])
  @@index([parentContactId, status])
  @@index([classTeacherStaffId, status])
  @@map("chat_threads")
}

model ChatMessage {
  id                    String     @id @default(uuid()) @db.Uuid
  threadId              String     @map("thread_id") @db.Uuid
  senderParentContactId String?    @map("sender_parent_contact_id") @db.Uuid
  senderParentRole      String?    @map("sender_parent_role")
  senderStaffId         String?    @map("sender_staff_id") @db.Uuid
  body                  String     @db.Text
  isDeleted             Boolean    @default(false) @map("is_deleted")
  deletedAt             DateTime?  @map("deleted_at")
  deletedByPartyType    String?    @map("deleted_by_party_type")
  deletedById           String?    @map("deleted_by_id") @db.Uuid
  editedAt              DateTime?  @map("edited_at")
  readAt                DateTime?  @map("read_at")
  createdAt             DateTime   @default(now()) @map("created_at")
  thread                ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([threadId, isDeleted, createdAt])
  @@map("chat_messages")
}

model ChatAdminAccessLog {
  id                String   @id @default(uuid()) @db.Uuid
  threadId          String   @map("thread_id") @db.Uuid
  accessedByStaffId String   @map("accessed_by_staff_id") @db.Uuid
  accessReason      String?  @map("access_reason") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([threadId])
  @@index([accessedByStaffId])
  @@map("chat_admin_access_log")
}

model NotificationRule {
  id                          String      @id @default(uuid()) @db.Uuid
  schoolId                    String      @map("school_id") @db.Uuid
  trigger                     String
  name                        String      @db.VarChar(200)
  description                 String?     @db.Text
  isEnabled                   Boolean     @default(true) @map("is_enabled")
  config                      Json        @db.JsonB
  cronExpression              String?     @map("cron_expression") @db.VarChar(50)
  lastRunAt                   DateTime?   @map("last_run_at")
  lastRunStatus               String?     @map("last_run_status")
  lastRunNotificationsCreated Int?        @map("last_run_notifications_created")
  createdByStaffId            String      @map("created_by_staff_id") @db.Uuid
  createdAt                   DateTime    @default(now()) @map("created_at")
  updatedAt                   DateTime    @updatedAt @map("updated_at")
  updatedByStaffId            String?     @map("updated_by_staff_id") @db.Uuid
  school                      School      @relation(fields: [schoolId], references: [id])
  triggeredBroadcasts         Broadcast[]

  @@unique([schoolId, trigger])
  @@map("notification_rules")
}

model NotificationLog {
  id                   String   @id @default(uuid()) @db.Uuid
  schoolId             String   @map("school_id") @db.Uuid
  broadcastRecipientId String?  @map("broadcast_recipient_id") @db.Uuid
  channel              String
  recipientType        String   @map("recipient_type")
  recipientId          String   @map("recipient_id") @db.Uuid
  status               String
  deviceTokenSuffix    String?  @map("device_token_suffix") @db.VarChar(10)
  errorMessage         String?  @map("error_message") @db.Text
  isStubbed            Boolean  @default(false) @map("is_stubbed")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([schoolId, createdAt])
  @@index([broadcastRecipientId])
  @@map("notification_log")
}

model PromotionRun {
  id                  String   @id @default(uuid()) @db.Uuid
  schoolId            String   @map("school_id") @db.Uuid
  fromAcademicYearId  String   @map("from_academic_year_id") @db.Uuid
  toAcademicYearId    String   @map("to_academic_year_id") @db.Uuid
  fromClassId         String   @map("from_class_id") @db.Uuid
  className           String   @map("class_name") @db.VarChar(100)
  totalStudents       Int      @map("total_students")
  promoted            Int      @default(0)
  retained            Int      @default(0)
  graduated           Int      @default(0)
  transferredOut      Int      @map("transferred_out") @default(0)
  droppedOut          Int      @map("dropped_out") @default(0)
  executedByStaffId   String   @map("executed_by_staff_id") @db.Uuid
  executedAt          DateTime @default(now()) @map("executed_at")
  notes               String?  @db.Text
  rollbackScope       String?  @map("rollback_scope") @db.VarChar(50)
  rolledBackGradeIds  String[] @map("rolled_back_grade_ids") @db.Uuid
  rolledBackStudentIds String[] @map("rolled_back_student_ids") @db.Uuid
  school              School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId, fromAcademicYearId])
  @@map("promotion_runs")
}

model SupportAccessGrant {
  id              String        @id @default(uuid()) @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid
  platformOwnerId String        @map("platform_owner_id") @db.Uuid
  reason          String        @db.VarChar(500)
  duration        Int
  requestedAt     DateTime      @default(now()) @map("requested_at")
  expiresAt       DateTime      @map("expires_at")
  revokedAt       DateTime?     @map("revoked_at")
  revokedBy       String?       @map("revoked_by") @db.Uuid

  school        School        @relation(fields: [schoolId], references: [id])
  platformOwner PlatformOwner @relation(fields: [platformOwnerId], references: [id])

  @@map("support_access_grants")
}

model PlatformOwner {
  id                  String               @id @default(uuid()) @db.Uuid
  firstName           String               @map("first_name") @db.VarChar(100)
  lastName            String               @map("last_name") @db.VarChar(100)
  email               String               @unique @db.VarChar(255)
  passwordHash        String?              @map("password_hash")
  status              String               @default("active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  supportAccessGrants   SupportAccessGrant[]
  schoolStatusHistories SchoolStatusHistory[]

  @@map("platform_owners")
}

model SchoolStatusHistory {
  id         String       @id @default(uuid()) @db.Uuid
  schoolId   String       @map("school_id") @db.Uuid
  fromStatus SchoolStatus @map("from_status")
  toStatus   SchoolStatus @map("to_status")
  changedBy  String       @map("changed_by") @db.Uuid
  reason     String       @db.Text
  changedAt  DateTime     @default(now()) @map("changed_at")
  metadata   Json?        @db.JsonB

  school        School        @relation(fields: [schoolId], references: [id])
  platformOwner PlatformOwner @relation(fields: [changedBy], references: [id])

  @@map("school_status_history")
}

enum SchoolStatus {
  ACTIVE
  PAUSED
  ARCHIVED
  DELETED
  PURGED
}

